# Server
PORT=3001

# CORS - lista separada por comas de origenes permitidos para el frontend
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# Auth
JWT_SECRET=

# SQL Server connection
DB_HOST=localhost
DB_PORT=
# Nombre de instancia con nombre (ej: SQLEXPRESS). Dejar vacio si se conecta por puerto/instancia default.
DB_INSTANCE_NAME=
DB_USER=
DB_PASSWORD=
DB_NAME=PiwiDB
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true
